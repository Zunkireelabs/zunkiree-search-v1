# =============================================================================
# Zunkiree Search Backend — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- Required: Core Services ---
OPENAI_API_KEY=sk-...
PINECONE_API_KEY=
PINECONE_HOST=https://your-index.svc.pinecone.io
PINECONE_INDEX_NAME=zunkiree-search
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Required: App Security ---
API_SECRET_KEY=change-this-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Query Settings (defaults shown) ---
# MAX_QUERY_LENGTH=500
# TOP_K_CHUNKS=5
# CONFIDENCE_THRESHOLD=0.25

# --- LLM Configuration (defaults shown) ---
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_MODEL_PREMIUM=gpt-4o
# LLM_TEMPERATURE=0.3
# LLM_MAX_TOKENS=500

# --- Embeddings (defaults shown) ---
# EMBEDDING_MODEL=text-embedding-3-large
# EMBEDDING_DIMENSIONS=3072

# --- Email Verification (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# --- Payments: Stripe (optional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Payments: eSewa (optional) ---
ESEWA_MERCHANT_CODE=
ESEWA_SECRET_KEY=
ESEWA_SANDBOX=true

# --- Payments: Khalti (optional) ---
KHALTI_SECRET_KEY=
KHALTI_SANDBOX=true

# --- Meta Messaging / Instagram Chatbot ---
META_APP_SECRET=
META_VERIFY_TOKEN=
CHATBOT_ENCRYPTION_KEY=
# CHATBOT_MAX_HISTORY=10
# CHATBOT_CONVERSATION_TTL_DAYS=7
